{
  "name": "copywright-rag",
  "version": "0.1.0",
  "description": "AI-powered UX copywriting tool with RAG, Figma MCP, and pluggable LLM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "ux",
    "copywriting",
    "rag",
    "ai",
    "figma",
    "mcp"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@ai-sdk/openai": "^3.0.58",
    "@google/genai": "^1.51.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.174",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vercel/node": "^5.7.15",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
